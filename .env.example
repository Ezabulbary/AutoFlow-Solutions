# ─────────────────────────────────────────────────────────────
# AutoFlow Solutions — environment configuration
# Copy this file to `.env.local` and fill in your real values.
# Payments run in DEMO MODE by default, but accounts/dashboard need a database.
# ─────────────────────────────────────────────────────────────

# ── Database (REQUIRED for accounts, dashboard, payment history) ──
# A MongoDB connection string. Free tier: https://www.mongodb.com/atlas
# Create a cluster → "Connect" → "Drivers" → copy the URI and add your DB name.
# Collections are created automatically on first use.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/autoflow?retryWrites=true&w=majority

# ── Auth (REQUIRED) ──
# A long random secret used to sign session cookies (min 32 chars).
# Generate one: `openssl rand -base64 48`
SESSION_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS

# Whoever registers (or signs in with Google) using this email becomes SUPER ADMIN.
SUPER_ADMIN_EMAIL=ezabul.bary@gmail.com

# ── Google sign-in (optional — email/password works without it) ──
# Create OAuth credentials: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <your-site>/api/auth/google/callback
GOOGLE_CLIENT_ID=REPLACE_WITH_YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=REPLACE_WITH_YOUR_GOOGLE_CLIENT_SECRET

# Public site URL — used for SEO/OpenGraph and the Google OAuth redirect.
NEXT_PUBLIC_SITE_URL=https://autoflowsolutions.com

# ── Email for password reset (optional) ──
# Without these, "forgot password" still works in dev — the reset link is
# printed to the server console instead of emailed.
# Get a free key at https://resend.com (then verify your sender domain).
RESEND_API_KEY=
EMAIL_FROM=AutoFlow Solutions <onboarding@resend.dev>

# Demo mode.
#   true  (or unset) → checkout is simulated, no real charges, demo banners shown.
#   false            → live payments using the keys below, banners hidden.
NEXT_PUBLIC_DEMO_MODE=true

# ── Stripe (card payments) ──
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=REPLACE_WITH_YOUR_STRIPE_SECRET_KEY
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=REPLACE_WITH_YOUR_STRIPE_PUBLISHABLE_KEY

# ── Coinbase Commerce (crypto payments) ──
# Get this from https://beta.commerce.coinbase.com/settings/security
COINBASE_COMMERCE_API_KEY=REPLACE_WITH_YOUR_COINBASE_COMMERCE_API_KEY

# ── PayPal (optional) ──
# Get these from https://developer.paypal.com/dashboard/applications
NEXT_PUBLIC_PAYPAL_CLIENT_ID=REPLACE_WITH_YOUR_PAYPAL_CLIENT_ID
